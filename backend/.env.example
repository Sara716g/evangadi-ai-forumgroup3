# Server Configuration
PORT=3777

# Database Credentials
DB_USER=your-db-user
DB_PASS=your-db-password
DB_HOST=localhost
DB_NAME=your-db-name

# JWT Configuration
JWT_SECRET=your-random-secret-key-here
JWT_EXPIRES_IN=1d

# Gemini API (Used for Vector Embeddings)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_TEXT_MODEL=gemini-2.5-flash

# Vector Search Thresholds & Settings
RECOMMEND_THRESHOLD=0.75
RECOMMEND_K=5

# RAG (user-owned PDFs)
RAG_UPLOAD_DIR=uploads/rag
RAG_MAX_UPLOAD_MB=5
RAG_CHUNK_CHARS=900
RAG_CHUNK_OVERLAP=120
RAG_MAX_CHUNKS_PER_DOC=1000
RAG_MAX_PDFS_PER_USER=20
RAG_MIN_TEXT_CHARS=50
RAG_SEARCH_THRESHOLD=0.45
RAG_SEARCH_K=10

# SMTP (Gmail for Forgot Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=your-email@gmail.com

# Frontend URL
FRONTEND_URL=http://localhost:5173
